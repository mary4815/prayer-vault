# Copy to .env and fill in. NEVER commit .env.
PORT=8787
PUBLIC_BASE_URL=http://localhost:8787
WEB_ORIGIN=http://localhost:5500          # where index.html is served from (CORS)

# --- Supabase ---  Dashboard > Project Settings > API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY   # secret! server only

# --- Stripe ---  dashboard.stripe.com > Developers > API keys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx            # from `stripe listen` or dashboard webhook
DONATION_SUCCESS_URL=http://localhost:5500/index.html?donated=1
DONATION_CANCEL_URL=http://localhost:5500/index.html?donated=0

# --- Subscriptions (paid plans) ---
# Create two recurring Products/Prices in Stripe (Plus + Church), copy their price IDs.
STRIPE_PRICE_PLUS=price_xxx                # e.g. $7.99/mo recurring price
STRIPE_PRICE_CHURCH=price_xxx              # e.g. $19.99/mo recurring price
BILLING_SUCCESS_URL=http://localhost:5500/index.html?upgraded=1
BILLING_CANCEL_URL=http://localhost:5500/index.html?upgraded=0
BILLING_RETURN_URL=http://localhost:5500/index.html?page=profile   # return from Stripe Customer Portal

# --- Email (Resend) ---  resend.com/api-keys
RESEND_API_KEY=re_xxx
EMAIL_FROM=Prayer Vault <noreply@yourdomain.com>

# --- WhatsApp (Twilio) ---  console.twilio.com
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # your Twilio WhatsApp sender / sandbox

# --- AI Prayer Companion (Anthropic / Claude) ---  console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxx                 # secret! server only — powers the Companion
AI_MODEL_CHAT=claude-sonnet-4-6              # chat + testimony writing
AI_MODEL_FAST=claude-haiku-4-5-20251001      # cheap verse lookups
AI_DAILY_LIMIT=40                            # max Companion messages per user per day
